\@writefile{toc}{\contentsline {subsubsection}{Effect on fractional coverage of $\sin ^2\theta _{23}$ differentiable from MM }{151}{subsubsection*.10}\protected@file@percent }
\newlabel{subsec:frac-DM}{{6.3.3}{151}{Effect on fractional coverage of $\sin ^2\theta _{23}$ differentiable from MM }{subsubsection*.10}{}}
\newlabel{eq:chi2-sensitivity-DM-2}{{6.22}{151}{Effect on fractional coverage of $\sin ^2\theta _{23}$ differentiable from MM }{equation.6.3.22}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {6.9}{\ignorespaces \footnotesize  {Fraction of $\sin ^2\theta _{23}$ in Nature that can be differentiated from MM at $\geq 3\sigma $ using DUNE, T2HK, and DUNE + T2HK in the presence of $(L_e-L_\mu )$, $(L_e-L_\tau )$, or $(L_\mu -L_\tau )$ symmetries (dotted curves) in left, middle, and right panels, respectively. We generate these curves following Eq.~\ref {eq:chi2-sensitivity-DM-2}, using the benchmark oscillation parameters and allowed ranges from Table~\ref {tab:oscillation-params}. We assume the benchmark choice of $\Delta m^2_{31}=2.522\times 10^{-3}$ eV$^2$ and consider NMO in Nature. For reference, we show fractional contributions of $\theta _{23}$ for our study under standard neutrino interaction (solid line) following the same benchmark values. The test statistic is minimized over 3$\sigma $ ranges in $\delta _{\mathrm  {CP}}$, $\Delta m^2_{31}$ (Refer Table~\ref {tab:oscillation-params}), and $V_{\alpha \beta } \in [1 \times 10^{-15}, 1 \times 10^{-13}]$ eV. \textit  {This sensitivity, being predominantly driven by disappearance statistics, is most affected by the presence of $L_{\mu }-L_{\tau }$ symmetry. } }}}{152}{figure.6.9}\protected@file@percent }
\newlabel{fig:frac_th23_DM}{{6.9}{152}{\footnotesize {Fraction of $\sin ^2\theta _{23}$ in Nature that can be differentiated from MM at $\geq 3\sigma $ using DUNE, T2HK, and DUNE + T2HK in the presence of $(L_e-L_\mu )$, $(L_e-L_\tau )$, or $(L_\mu -L_\tau )$ symmetries (dotted curves) in left, middle, and right panels, respectively. We generate these curves following Eq.~\ref {eq:chi2-sensitivity-DM-2}, using the benchmark oscillation parameters and allowed ranges from Table~\ref {tab:oscillation-params}. We assume the benchmark choice of $\Delta m^2_{31}=2.522\times 10^{-3}$ eV$^2$ and consider NMO in Nature. For reference, we show fractional contributions of $\theta _{23}$ for our study under standard neutrino interaction (solid line) following the same benchmark values. The test statistic is minimized over 3$\sigma $ ranges in $\delta _{\mathrm {CP}}$, $\Delta m^2_{31}$ (Refer Table~\ref {tab:oscillation-params}), and $V_{\alpha \beta } \in [1 \times 10^{-15}, 1 \times 10^{-13}]$ eV. \textit {This sensitivity, being predominantly driven by disappearance statistics, is most affected by the presence of $L_{\mu }-L_{\tau }$ symmetry. } }}{figure.6.9}{}}
\@writefile{toc}{\contentsline {subsubsection}{Effect on excluding HO solutions of $\sin ^2\theta _{23}$ }{153}{subsubsection*.11}\protected@file@percent }
\newlabel{subsec:frac-octant}{{6.3.3}{153}{Effect on excluding HO solutions of $\sin ^2\theta _{23}$ }{subsubsection*.11}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {6.10}{\ignorespaces \footnotesize  {Fraction of $\sin ^2\theta _{23}$ in Nature that can exclude wrong octant solutions of $\sin ^2\theta _{23}$ at $\geq 3\sigma $ using DUNE, T2HK, and DUNE + T2HK in the presence of $(L_e-L_\mu )$, $(L_e-L_\tau )$, or $(L_\mu -L_\tau )$ symmetries (dotted curves) in left, middle, and right panels, respectively. We generate these curves following Eq.~\ref {eq:chi2-sensitivity-oct-2}, using the benchmark oscillation parameters and allowed ranges from Table~\ref {tab:oscillation-params}. We assume the benchmark choice of $\delta _{\mathrm  {CP}}$ as $223^\circ $ and consider the LO ($i.e., 0.4\leq \sin ^2\theta _{23}\leq 0.5$) as a true octant of $\theta _{23}$ and excluding the HO ($i.e., 0.5\leq \sin ^2\theta _{23}\leq 0.6$), treating NMO as the underlying mass hierarchy in nature. For reference, we show this fraction under standard neutrino interaction (solid line) following the same benchmark values. The test statistic is minimized over 3$\sigma $ ranges in $\delta _{\mathrm  {CP}}$, $\Delta m^2_{31}$ (Refer Table~\ref {tab:oscillation-params}), and $V_{\alpha \beta } \in [1 \times 10^{-15}, 1 \times 10^{-13}]$ eV. \textit  {This sensitivity, being predominantly driven by appearance statistics, is most affected by the presence of $L_{\mu }-L_{\tau }$ symmetry. } }}}{153}{figure.6.10}\protected@file@percent }
\newlabel{fig:frac_th23_oct}{{6.10}{153}{\footnotesize {Fraction of $\sin ^2\theta _{23}$ in Nature that can exclude wrong octant solutions of $\sin ^2\theta _{23}$ at $\geq 3\sigma $ using DUNE, T2HK, and DUNE + T2HK in the presence of $(L_e-L_\mu )$, $(L_e-L_\tau )$, or $(L_\mu -L_\tau )$ symmetries (dotted curves) in left, middle, and right panels, respectively. We generate these curves following Eq.~\ref {eq:chi2-sensitivity-oct-2}, using the benchmark oscillation parameters and allowed ranges from Table~\ref {tab:oscillation-params}. We assume the benchmark choice of $\delta _{\mathrm {CP}}$ as $223^\circ $ and consider the LO ($i.e., 0.4\leq \sin ^2\theta _{23}\leq 0.5$) as a true octant of $\theta _{23}$ and excluding the HO ($i.e., 0.5\leq \sin ^2\theta _{23}\leq 0.6$), treating NMO as the underlying mass hierarchy in nature. For reference, we show this fraction under standard neutrino interaction (solid line) following the same benchmark values. The test statistic is minimized over 3$\sigma $ ranges in $\delta _{\mathrm {CP}}$, $\Delta m^2_{31}$ (Refer Table~\ref {tab:oscillation-params}), and $V_{\alpha \beta } \in [1 \times 10^{-15}, 1 \times 10^{-13}]$ eV. \textit {This sensitivity, being predominantly driven by appearance statistics, is most affected by the presence of $L_{\mu }-L_{\tau }$ symmetry. } }}{figure.6.10}{}}
\newlabel{eq:chi2-sensitivity-oct-2}{{6.23}{154}{Effect on excluding HO solutions of $\sin ^2\theta _{23}$ }{equation.6.3.23}{}}
\citation{Nath:2015kjg,Machado:2015vwa,Agarwalla:2022xdo}
\@writefile{toc}{\contentsline {subsubsection}{Impact on CP coverage }{155}{subsubsection*.12}\protected@file@percent }
\newlabel{subsec:frac-CPV}{{6.3.3}{155}{Impact on CP coverage }{subsubsection*.12}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {6.11}{\ignorespaces \footnotesize  {Fraction of $\delta _\mathrm  {CP}$ in Nature that can establish CPV at $\geq 3\sigma $ using DUNE, T2HK, and DUNE + T2HK in presence of $(L_e-L_\mu )$, $(L_e-L_\tau )$, or $(L_\mu -L_\tau )$ symmetries in dotted curves in left, middle, and right panels, respectively. We generate these curves following Eq.~\ref {eq:chi2-sensitivity-to-cp-coverage}, using the benchmark oscillation parameters and allowed ranges from Table~\ref {tab:oscillation-params} assuming NMO in Nature. We assume the benchmark choice of $\sin ^2\theta _{23}$ as $0.455$ ($i.e.,$ in LO) and marginalize over $3\sigma $ range of $\Delta m^2_{31}$ and $\sin ^2\theta _{23}$ as mentioned in \ref {tab:oscillation-params}. For reference, we show CP coverage under standard neutrino interaction (solid line) following the same benchmark values. \textit  {If subdominant long-range interaction exists in Nature, then under each symmetry, expected CP coverage in leptonic CP violation at $\geq 3\sigma $ will decrease due to the degeneracies arising by minimizing over $V_{\alpha \beta } \text  { and } \sin ^2\theta _{23}$ in test statistic.}}}}{155}{figure.6.11}\protected@file@percent }
\newlabel{fig:CPC_LRI}{{6.11}{155}{\footnotesize {Fraction of $\delta _\mathrm {CP}$ in Nature that can establish CPV at $\geq 3\sigma $ using DUNE, T2HK, and DUNE + T2HK in presence of $(L_e-L_\mu )$, $(L_e-L_\tau )$, or $(L_\mu -L_\tau )$ symmetries in dotted curves in left, middle, and right panels, respectively. We generate these curves following Eq.~\ref {eq:chi2-sensitivity-to-cp-coverage}, using the benchmark oscillation parameters and allowed ranges from Table~\ref {tab:oscillation-params} assuming NMO in Nature. We assume the benchmark choice of $\sin ^2\theta _{23}$ as $0.455$ ($i.e.,$ in LO) and marginalize over $3\sigma $ range of $\Delta m^2_{31}$ and $\sin ^2\theta _{23}$ as mentioned in \ref {tab:oscillation-params}. For reference, we show CP coverage under standard neutrino interaction (solid line) following the same benchmark values. \textit {If subdominant long-range interaction exists in Nature, then under each symmetry, expected CP coverage in leptonic CP violation at $\geq 3\sigma $ will decrease due to the degeneracies arising by minimizing over $V_{\alpha \beta } \text { and } \sin ^2\theta _{23}$ in test statistic.}}}{figure.6.11}{}}
\newlabel{eq:chi2-sensitivity-to-cp-coverage}{{6.24}{155}{Impact on CP coverage }{equation.6.3.24}{}}
